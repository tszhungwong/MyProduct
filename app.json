{
  "expo": {
    "name": "Product Selling App",
    "slug": "product-selling-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "productsellingapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
